#!/usr/bin/env bash
# Wrapper per avviare LTSIA-py
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Cerca virtualenv: .venv311 > .venv > python3 di sistema
if [ -d "$SCRIPT_DIR/.venv311" ]; then
  PYTHON="$SCRIPT_DIR/.venv311/bin/python"
elif [ -d "$SCRIPT_DIR/.venv" ]; then
  PYTHON="$SCRIPT_DIR/.venv/bin/python"
else
  PYTHON="python3"
fi

# Su Linux/ARM: evita che ctranslate2 crei troppe regioni OpenMP in parallelo
# (non necessario su macOS dove il flag era diverso)
export OMP_NUM_THREADS=1

exec "$PYTHON" "$SCRIPT_DIR/main.py" "$@"
